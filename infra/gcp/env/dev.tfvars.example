# Dev/lower-environment configuration for artnet-dev.com.
#
# Copy this file to dev.tfvars in this directory, then replace the placeholders:
#
#   cp infra/gcp/env/dev.tfvars.example infra/gcp/env/dev.tfvars
#   terraform -chdir=infra/gcp plan -var-file=env/dev.tfvars
#
# Do not commit env/dev.tfvars. It may contain account-specific IDs.

# Change this if the actual GCP project ID for artnet-dev.com differs.
project_id = "artnet-dev"

region          = "us-east4"
bucket_location = "US-EAST4"

# GCS bucket names are globally unique. If this name is already taken, keep the
# artnet-dev prefix and add the GCP project ID or another stable suffix.
bucket_name = "artnet-dev-image-upload-originals"

# Keep false so Terraform cannot destroy a bucket that still contains image data.
bucket_force_destroy = false

# Browser origins allowed to PUT directly to signed GCS URLs.
cors_allowed_origins = [
  "http://localhost:5173",
  "http://localhost:8080",
  "https://artnet-dev.com",
  "https://www.artnet-dev.com",
  "https://upload.artnet-dev.com",
]

# Public image URL returned by finalize responses in the lower environment.
public_base_url = "https://artworks.artnet-dev.com"

# Upload Function API CORS response origin. Use the concrete lower-env UI origin
# rather than * once the calling app domain is settled.
cors_allow_origin = "https://artnet-dev.com"

runtime_service_account_id           = "artnet-dev-upload-function"
runtime_service_account_display_name = "Artnet Dev Upload Function runtime"

# Cloudflare R2 lower-environment replication target. These are identifiers only,
# not secrets. Store the access key values in Secret Manager after apply.
r2_account_id = "REPLACE_WITH_CLOUDFLARE_ACCOUNT_ID"
r2_bucket     = "artnet-dev-image-upload-originals"

r2_access_key_id_secret_id     = "artnet-dev-r2-access-key-id"
r2_secret_access_key_secret_id = "artnet-dev-r2-secret-access-key"

labels = {
  app         = "artnet-image-upload"
  managed_by  = "terraform"
  environment = "dev"
  domain      = "artnet-dev-com"
}
